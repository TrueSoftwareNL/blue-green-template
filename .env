# =============================================================================
# Blue-Green Deployment Template — Environment Configuration
# =============================================================================
# This file is loaded by Docker Compose. Never commit this file to git.
# Copy .env.example to .env and adjust values for your environment.
# =============================================================================

# Project
COMPOSE_PROJECT_NAME=appname

# App Configuration
APP_REPLICAS=5
ACTIVE_ENV=blue

# Nginx (operates behind ProxyBuilder — HTTP only)
NGINX_HTTP_PORT=80

# Health Check Configuration (used by switching scripts)
HEALTH_CHECK_RETRIES=5
HEALTH_CHECK_INTERVAL=2

# PostgreSQL Configuration
POSTGRES_USER=appuser
POSTGRES_PASSWORD=changeme_secure_password
POSTGRES_DB=appdb
