# =============================================================================
# .gitignore — Blue-Green Deployment Template
# =============================================================================

# Environment configuration (contains secrets, passwords)
.env

# PostgreSQL data (persistent database files)
data/postgresql/*
!data/postgresql/.gitkeep

# Node.js dependencies
node_modules/

# Docker build artifacts
*.tar

# OS files
.DS_Store
Thumbs.db

# IDE files
.idea/
.vscode/
*.swp
*.swo
*~

# Log files
*.log
logs/
